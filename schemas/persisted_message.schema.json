{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tg-news-project.local/schemas/persisted_message.v1.json",
  "title": "Persisted Message Event",
  "description": "Confirmation that a message was successfully persisted to Postgres",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_timestamp",
    "event_version",
    "source_system",
    "trace_id",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Unique event identifier: {channel}:{message_id}",
      "pattern": "^[a-zA-Z0-9_]+:[0-9]+$"
    },
    "event_type": {
      "type": "string",
      "const": "persisted",
      "description": "Event type identifier"
    },
    "event_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was created (UTC)"
    },
    "event_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version of the schema"
    },
    "source_system": {
      "type": "string",
      "description": "System that generated this event",
      "examples": ["message-persister"]
    },
    "trace_id": {
      "type": "string",
      "format": "uuid",
      "description": "Distributed tracing ID for correlation"
    },
    "payload": {
      "type": "object",
      "required": [
        "message_id",
        "channel",
        "db_id",
        "persisted_at",
        "status"
      ],
      "properties": {
        "message_id": {
          "type": "integer",
          "description": "Telegram message ID",
          "minimum": 1
        },
        "channel": {
          "type": "string",
          "description": "Telegram channel username",
          "minLength": 1
        },
        "db_id": {
          "type": "string",
          "format": "uuid",
          "description": "PostgreSQL UUID primary key"
        },
        "persisted_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when persisted to database"
        },
        "status": {
          "type": "string",
          "enum": ["success", "duplicate", "error"],
          "description": "Persistence status"
        },
        "error_message": {
          "type": ["string", "null"],
          "description": "Error message if status is 'error'"
        }
      }
    }
  },
  "additionalProperties": false
}
