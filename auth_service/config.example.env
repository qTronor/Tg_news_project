# Auth service uses the SAME PostgreSQL instance as the main project,
# but a SEPARATE database (tg_news_auth) for PII isolation.
# The database is created by migrations/002_auth_schema.sql on first PG startup.

# Database — points to the shared PG container from docker-compose.infrastructure.yml
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@postgres:5432/tg_news_auth

# For local dev (without Docker network):
# AUTH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tg_news_auth

# JWT — MUST change in production! Use KMS-managed secret.
AUTH_JWT_SECRET_KEY=replace-with-random-256bit-key
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
AUTH_CORS_ORIGINS=["http://localhost:3000"]

# Rate limiting
AUTH_RATE_LIMIT_PER_MINUTE=30

# Bootstrap admin (optional, used on first startup only)
AUTH_ADMIN_BOOTSTRAP_EMAIL=admin@example.com
AUTH_ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!
